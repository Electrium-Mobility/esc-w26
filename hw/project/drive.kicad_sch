	(text_box "(Notes from Leo Before Task Assignment)\nMotor Phase Current -> Shunt Resistor -> Current Amplifier -> ADC -> FW, with\nIphase = Vadc / (Gain × Rshunt), where V_shunt = Vadc / Gain\n-> Note that Vadc comes from the op amp AFTER it amplifies the signal\n\nThe result from an OPAMP will be fed into an ADC, then current is calculated. \nADC must be timer triggered, so sampling happens when the mosfet is conducting\n\nFor each phase, need:\n- 1 shunt resistor\n- 2 traces for current sense (OPAMP+ and OPAMP-) [also called Kelvin sense connections]"
		(exclude_from_sim no)
		(at 250.825 86.995 0)
		(size 69.215 39.37)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "2d42525d-9d03-4a4c-b3ae-7fb964c30a34")
	)
	(text_box "for 100mV at 40A peak,\nR = 2.5mOhm"
		(exclude_from_sim no)
		(at 62.23 93.98 0)
		(size 26.67 5.08)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
