			)
			(justify left top)
		)
		(uuid "a560ce23-328a-470d-a6cf-33f3c434b6b0")
	)
	(text_box "Gain = Vadc/Vshunt = 3.3/0.1 = 33\ntaking G = 34 for standard values\nG = 1 + Rf/Ri (from 140 lol)\n34 = 1 + 33k/1k "
		(exclude_from_sim no)
		(at 22.86 163.83 0)
		(size 41.91 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
