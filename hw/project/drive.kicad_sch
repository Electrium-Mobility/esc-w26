			)
			(justify left top)
		)
		(uuid "42b8106b-e702-40df-a929-51f451a4c4d3")
	)
	(text_box "Gate Resistors (low val) on GHSx and LHSx"
		(exclude_from_sim no)
		(at 1.905 25.4 0)
		(size 25.4 5.08)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
