			)
			(justify left top)
		)
		(uuid "546c0935-3360-49bb-a8ca-8775c60f2fb5")
	)
	(text_box "Gmax = Vdd/(2*I_max*R_s) = 3.3*1000/(2*40*2.5) = 16.5\ntaking G = 15.5\nR22/R20 = 2G = 31\nR19/R21 = G - 0.5 = 15\nR20/R21 = 1 - 1/2G = 0.96774\n\ntaking R21 = 2k,\nR19 = 30k\nR20 = 1.9355 rounded to 2k for standard value\nR22 = 2*31 = 62k\n\n"
		(exclude_from_sim no)
		(at 86.36 156.21 0)
		(size 41.91 25.4)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
