			(justify left top)
		)
		(uuid "4516ea4c-a26e-4265-b011-12bf01fb4f22")
	)
	(text_box "Just a tad bit of info on current sensing with the SoC\n\nUM2896 5.6"
		(exclude_from_sim no)
		(at 252.984 143.51 0)
		(size 35.56 10.0822)
		(margins 0.9525 0.9525 0.9525 0.9525)
