		(uuid "530394b0-132b-43f2-87a1-fa9f1a799a2f")
	)
	(text_box "Gmax = Vdd/(2*I_max*R_s) = 3.3*1000/(2*40*2.5) = 16.5\ntaking G = 15.5\nR22/R20 = 2G = 31\nR19/R21 = G - 0.5 = 15\nR20/R21 = 1 - 1/2G = 0.96774\n\ntaking R21 = 2k,\nR19 = 30k\nR20 = 1.9355 rounded to 2k for standard value\nR22 = 2*31 = 62k\n\n"
		(exclude_from_sim no)
		(at 86.36 156.21 0)
		(size 41.91 25.4)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type color)
			(color 188 237 255 0.67)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "6e36387a-ad7d-49a5-8fb9-ecfa19b79f01")
	)
	(text_box "this is inspired from AN5397, fig 8 on pg 10\nalso found in evspin32g4 dual schematic"
		(exclude_from_sim no)
		(at 153.67 158.75 0)
		(size 41.91 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
