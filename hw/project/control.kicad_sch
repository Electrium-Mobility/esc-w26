	(text_box "Temperature Monitoring\n\n10k NTC is standard, but is taken at 25 deg C\n\nSince active operation temp > room temp, use R_bias = 4.7k\nto shift ADC midpoint (1.65V) over active temp range \n(check datasheet for when R_NTC drops to 4.7k exactly)"
		(exclude_from_sim no)
		(at 139.7 129.4915 0)
