	(text_box "Bus Voltage Monitoring\n\nVM_max = 78V, but take as 82.5V to avoid clipping\n\n82.5V / 3.3V = 25.0 = Rbus_2 / (Rbus_1 + Rbus_2)\n=> Rbus_1 / Rbus_2 = 24.0"
		(exclude_from_sim no)
