	)
	(text_box "*Route both at EPAD:\n\n1. Gate Drivers Power Ground (PGND)\n-> Zone near VM_IN connector and low-side MOSFETs\n\n2. Control Logic Ground (VSS)\n-> Zone near MCU application circuitry"
		(exclude_from_sim no)
		(at 91.44 179.1099 0)
		(size 55.88 17.7401)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "2a6dfb9f-a53a-493f-91b4-030873f0d5fd")
	)
	(text_box "V_DS Monitoring Protection / Short Circuit REFerence (5.2.5)\n\nNormally Open, so feature enabled when header is NOT on\n\nCapacitor is N.M. There in case of false positives.\n\n-> Resistor divider based on EVSPIN32G4 (but to be revised based on desired trip current with chosen MOSFETs, unless simi-same specs)"
		(exclude_from_sim no)
		(at 210.82 93.98 0)
		(size 71.12 20.3053)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "5e44799f-f670-4a3c-8efe-b8cf5f4148cc")
	)
	(text_box "Internal 3.3V Linear Regulator\n\nEnabled (5.1.2), VCC-REGIN jumper for external VCC cfg\n"
		(exclude_from_sim no)
		(at 236.22 68.58 0)
		(size 45.72 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "63a41657-c2aa-401b-8fb3-b2980d0326b4")
	)
	(text_box "Internal VCC Buck Regulator\n\nEnabled (5.1.1), value configured in FW (\"Disabled\" cfg not implemented)"
		(exclude_from_sim no)
		(at 236.22 58.42 0)
		(size 45.72 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "6a8062a1-72d8-45b4-9140-244cc6d76dd2")
	)
	(text_box "Temperature Monitoring\n\n10k NTC is standard, but is taken at 25 deg C\n\nSince active operation temp > room temp, use R_bias = 4.7k to shift ADC midpoint (1.65V) over active temp range(check datasheet for when R_NTC drops to 4.7k exactly)"
		(exclude_from_sim no)
		(at 167.64 149.86 0)
		(size 114.3 14.1714)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(face "KiCad Font")
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "b2aecc59-5b9d-4b54-a872-c103a2051078")
	)
	(text_box "ADC Positive Reference Voltage\n\nEVSPIN32G4 uses VREF+ instead of VDD on the temp sense and current sense dividers\n\n200 on NRST to prevent 3V3 to GND short when switch is pressed"
		(exclude_from_sim no)
		(at 236.22 35.56 0)
		(size 45.72 20.32)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "bf906a37-66e2-46a3-a9d3-c5748c3e9b81")
	)
	(text_box "Motor Supply Voltage\n\nC_M = 220nF ( = C_VM), while the bulk C_VMpol (3 x 100uF) will be in Peripherals"
		(exclude_from_sim no)
		(at 210.82 114.3 0)
		(size 71.12 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "d4ee9a4c-5bc9-4180-9ec1-5bee62498a6c")
	)
	(text_box "Bus Voltage Monitoring\n\nVM_max = 78V, but take as 82.5V to avoid clipping\n\n82.5V / 3.3V = 25.0 = Rbus_2 / (Rbus_1 + Rbus_2) => Rbus_1 / Rbus_2 = 24.0"
		(exclude_from_sim no)
		(at 167.64 137.16 0)
		(size 114.3 12.7)
		(margins 0.9525 0.9525 0.9525 0.9525)
